{{!-- partials/petals-cluster.hbs --}}
{{#if @custom.show_petals}}
<div class="petals-cluster {{location}}">
  <svg class="petal petal-1" viewBox="0 0 14 22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0,0 C3,-10 9,-16 0,-22 C-9,-16 -3,-10 0,0 Z" transform="translate(7, 22)"/></svg>
  <svg class="petal petal-2" viewBox="0 0 14 22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0,0 C3,-10 9,-16 0,-22 C-9,-16 -3,-10 0,0 Z" transform="translate(7, 22)"/></svg>
  <svg class="petal petal-3" viewBox="0 0 14 22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0,0 C3,-10 9,-16 0,-22 C-9,-16 -3,-10 0,0 Z" transform="translate(7, 22)"/></svg>
  {{#match @custom.petal_density "medium"}}
    <svg class="petal petal-4" viewBox="0 0 14 22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0,0 C3,-10 9,-16 0,-22 C-9,-16 -3,-10 0,0 Z" transform="translate(7, 22)"/></svg>
  {{/match}}
  {{#match @custom.petal_density "dense"}}
    <svg class="petal petal-4" viewBox="0 0 14 22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0,0 C3,-10 9,-16 0,-22 C-9,-16 -3,-10 0,0 Z" transform="translate(7, 22)"/></svg>
  {{/match}}
</div>
{{/if}}
