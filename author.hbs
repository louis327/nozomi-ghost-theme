{{!< default}}

<section class="post-list" style="padding-top: 60px;">
  <div class="label-mono accent">AUTHOR</div>
  <h1 style="font-family: var(--font-serif); font-size: 44px; margin: 12px 0 8px;">{{author.name}}</h1>
  {{#if author.bio}}
    <p style="color: var(--text-secondary); max-width: 600px; margin: 0 0 48px;">{{author.bio}}</p>
  {{/if}}

  {{#foreach posts}}
    <article class="post-card">
      <div class="meta label-mono accent">
        {{date published_at format="MMM DD, YYYY"}}{{#if primary_tag}} · {{primary_tag.name}}{{/if}}
      </div>
      <h2><a href="{{url}}">{{title}}</a></h2>
      {{#if @custom.show_post_excerpts}}
        <p class="excerpt">{{excerpt words="32"}}</p>
      {{/if}}
      <div class="footer-meta">{{reading_time}} · <a href="{{url}}">Read letter →</a></div>
    </article>
  {{/foreach}}
</section>
