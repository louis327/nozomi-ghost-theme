<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{meta_title}}</title>
  {{ghost_head}}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" type="text/css" href="{{asset "built/screen.css"}}" />
  <style>:root { --accent: {{@custom.accent_color}}; }</style>
</head>
<body class="{{body_class}}">
  <header class="site-header">
    <a class="site-mark" href="{{@site.url}}">
      <svg class="petal" viewBox="0 0 14 22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M0,0 C3,-10 9,-16 0,-22 C-9,-16 -3,-10 0,0 Z" transform="translate(7, 22)"/></svg>
      <span class="wordmark">{{@site.title}}</span>
    </a>
    <nav class="site-nav">
      {{navigation}}
      <a class="btn-subscribe" href="#/portal/signup" data-portal="signup">Subscribe</a>
    </nav>
  </header>

  <main>
    {{{body}}}
  </main>

  <footer class="site-footer">
    <span>© {{date format="YYYY"}} Nozomi Network</span>
    <span>{{@custom.footer_tagline}}</span>
    <span><a href="https://nozomi.network">↗ nozomi.network</a></span>
  </footer>

  {{ghost_foot}}
</body>
</html>
